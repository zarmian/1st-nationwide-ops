# 1st Nationwide Ops — environment variables
# Copy this file to .env.local for local dev, or set these in Vercel project settings.

# ── Database (Supabase Postgres, EU-West London region) ──────────────────────
# Pooled connection (used by app at runtime). Append ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrate). Port 5432, no pgbouncer.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
# In production this is your Vercel URL. Locally use http://localhost:3000.
NEXTAUTH_URL="http://localhost:3000"

# ── App ──────────────────────────────────────────────────────────────────────
# Public URL used in emails / report PDFs. No trailing slash.
APP_URL="http://localhost:3000"
# Default region for new sites (LONDON or OUTSIDE_LONDON)
DEFAULT_REGION="LONDON"

# ── Vercel Cron ──────────────────────────────────────────────────────────────
# Vercel sends Authorization: Bearer <CRON_SECRET> with each cron request.
# In production this MUST be set; locally it can be omitted (auth is bypassed
# in non-production).
CRON_SECRET=""
