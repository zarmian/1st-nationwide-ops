// =============================================================
//  1st Nationwide Ops — Prisma schema (v1.2)
//  Postgres / Supabase EU-West
// =============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, citext]
}

// ----------- Enums -----------

enum UserRole {
  ADMIN
  DISPATCHER
  OFFICER
}

enum SiteType {
  COMMERCIAL
  RESIDENTIAL
  RETAIL
  STORAGE
  INDUSTRIAL
  OTHER
}

enum ServiceTag {
  ALARM_RESPONSE
  KEYHOLDING
  LOCKUP
  UNLOCK
  VPI
  PATROL
  STATIC_GUARDING
  DOG_HANDLER
  ADHOC
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum CustomerType {
  CORPORATE
  RESIDENTIAL
  RESELLER
}

enum KeyType {
  KEY
  FOB
  PADLOCK
  CODE
}

enum KeyStatus {
  WITH_US
  WITH_OFFICER
  WITH_CUSTOMER
  LOST
  RETIRED
}

enum PatrolFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum ScheduleKind {
  PATROL
  VPI
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum VisitStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  LATE
  MISSED
}

enum OnboardingStage {
  PROPOSED
  SURVEY
  KEY_COLLECTION
  GO_LIVE
  CANCELLED
}

enum CustomerProgram {
  TESCO
  SHURGARD
  OTHER
}

enum AlarmSource {
  ARC_EMAIL
  ARC_PHONE
  PARTNER_EMAIL
  PARTNER_PHONE
  CUSTOMER_PHONE
  MANUAL
  WEBHOOK
}

enum PartnerRole {
  CUSTOMER
  SUBCONTRACTOR
  BOTH
}

enum PartnerChannel {
  EMAIL
  PHONE
  THEIR_APP
  WHATSAPP
  PORTAL
}

enum JobType {
  ALARM_RESPONSE
  PATROL
  LOCK
  UNLOCK
  KEY_COLLECTION
  KEY_DROPOFF
  SURVEY
  VPI
  ADHOC
  STATIC_GUARDING_SHIFT
  DOG_HANDLER_SHIFT
}

enum JobSource {
  SCHEDULED
  ALARM
  PARTNER_REQUEST
  CUSTOMER_REQUEST
  ONBOARDING
  AD_HOC
}

enum JobStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  REVIEW_PENDING
  APPROVED
  SENT_TO_CLIENT
  CLOSED
  CANCELLED
}

enum ResponderType {
  INTERNAL_OFFICER
  PARTNER
  EXTERNAL_NAMED
}

enum SubmissionForm {
  ALARM_RESPONSE
  PATROL
  LOCK
  UNLOCK
  KEY_COLLECTION
  KEY_DROPOFF
  VPI
  ADHOC
}

enum TemplateScope {
  GLOBAL
  CUSTOMER
  PARTNER
  SITE
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED_AND_APPROVED
}

enum ReportChannel {
  EMAIL
  PORTAL_DOWNLOAD
  WHATSAPP
}

enum ReportStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum AlarmPriority {
  LOW
  MEDIUM
  HIGH
}

enum AlarmOutcome {
  FALSE_ALARM
  GENUINE
  RESOLVED
  ESCALATED_TO_POLICE
  OTHER
}

// ----------- Models -----------

model Region {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  leadUserId  String?  @db.Uuid
  leadUser    User?    @relation("RegionLead", fields: [leadUserId], references: [id])
  notes       String?

  sites       Site[]
  officers    User[]   @relation("OfficerRegion")
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique @db.Citext
  name          String
  passwordHash  String?
  phone         String?
  siaNumber     String?  @unique
  role          UserRole
  regionId      Int?
  region        Region?  @relation("OfficerRegion", fields: [regionId], references: [id])
  active        Boolean  @default(true)
  onDuty        Boolean  @default(false)
  lastLat       Float?
  lastLng       Float?
  lastSeenAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  defaultResponderForSites Site[]              @relation("DefaultResponder")
  patrolSchedules          PatrolSchedule[]
  patrolVisits             PatrolVisit[]
  lockUnlockSchedules      LockUnlockSchedule[]
  alarmEventsAssigned      AlarmEvent[]        @relation("AlarmAssignedTo")
  keysHeld                 Key[]               @relation("KeyHolder")
  keyMovementsFrom         KeyMovement[]       @relation("KeyMoveFrom")
  keyMovementsTo           KeyMovement[]       @relation("KeyMoveTo")
  keyMovementsSignedOff    KeyMovement[]       @relation("KeyMoveSignedOff")
  activityLogs             ActivityLog[]
  regionsLed               Region[]            @relation("RegionLead")
  jobsAsResponder          Job[]               @relation("JobResponderUser")
  formSubmissions          FormSubmission[]    @relation("SubmittedByUser")
  reportReviews            ReportReview[]      @relation("ReportReviewer")
  formTemplatesAuthored    FormTemplate[]      @relation("FormTemplateAuthor")

  @@index([regionId, role])
}

model Customer {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String        @unique
  type            CustomerType  @default(CORPORATE)
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  billingAddress  String?
  contractRef     String?
  contractStart   DateTime?
  contractEnd     DateTime?
  notes           String?
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sites           Site[]
  jobs            Job[]
  contacts        CustomerContact[]
  formTemplates   FormTemplate[]

  @@index([name])
}

model CustomerContact {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId  String   @db.Uuid
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  role        String?
  email       String?
  phone       String?
  ref         String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
}

model Site {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String?      @unique
  name                  String
  addressLine           String
  postcode              String
  postcodeFormatted     String
  city                  String?
  lat                   Float?
  lng                   Float?
  type                  SiteType     @default(COMMERCIAL)
  regionId              Int?
  region                Region?      @relation(fields: [regionId], references: [id])
  customerId            String?      @db.Uuid
  customer              Customer?    @relation(fields: [customerId], references: [id])
  partnerId             String?      @db.Uuid
  partner               Partner?     @relation("PartnerSites", fields: [partnerId], references: [id])
  defaultResponderId    String?      @db.Uuid
  defaultResponder      User?        @relation("DefaultResponder", fields: [defaultResponderId], references: [id])
  services              ServiceTag[] @default([])
  riskLevel             RiskLevel    @default(LOW)
  notes                 String?
  active                Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  keys                  Key[]
  keySets               KeySet[]
  accessInstruction     AccessInstruction?
  patrolSchedules       PatrolSchedule[]
  patrolVisits          PatrolVisit[]
  lockUnlockSchedules   LockUnlockSchedule[]
  alarmEvents           AlarmEvent[]
  onboardingPipelines   OnboardingPipeline[]
  jobs                  Job[]
  formSubmissions       FormSubmission[]
  formTemplates         FormTemplate[]

  @@index([regionId])
  @@index([customerId])
  @@index([partnerId])
  @@index([postcode])
  @@index([type])
  @@index([active])
}

model KeySet {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId      String   @db.Uuid
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  internalNo  String?  @unique
  label       String
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  keys        Key[]

  @@index([siteId])
}

model Key {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  internalNo          String?       @unique
  label               String
  type                KeyType
  siteId              String?       @db.Uuid
  site                Site?         @relation(fields: [siteId], references: [id])
  keySetId            String?       @db.Uuid
  keySet              KeySet?       @relation(fields: [keySetId], references: [id], onDelete: SetNull)
  copyOfId            String?       @db.Uuid
  copyOf              Key?          @relation("KeyCopies", fields: [copyOfId], references: [id], onDelete: SetNull)
  copies              Key[]         @relation("KeyCopies")
  duplicable          Boolean       @default(true)
  currentHolderUserId String?       @db.Uuid
  currentHolder       User?         @relation("KeyHolder", fields: [currentHolderUserId], references: [id])
  status              KeyStatus     @default(WITH_US)
  qrId                String?       @unique
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  movements           KeyMovement[]

  @@index([siteId])
  @@index([keySetId])
  @@index([copyOfId])
  @@index([currentHolderUserId])
  @@index([status])
}

model KeyMovement {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyId           String   @db.Uuid
  key             Key      @relation(fields: [keyId], references: [id], onDelete: Cascade)
  fromUserId      String?  @db.Uuid
  fromUser        User?    @relation("KeyMoveFrom", fields: [fromUserId], references: [id])
  toUserId        String?  @db.Uuid
  toUser          User?    @relation("KeyMoveTo", fields: [toUserId], references: [id])
  occurredAt      DateTime @default(now())
  reason          String?
  notes           String?
  signedOffById   String?  @db.Uuid
  signedOffBy     User?    @relation("KeyMoveSignedOff", fields: [signedOffById], references: [id])

  @@index([keyId, occurredAt])
}

model AccessInstruction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId          String   @unique @db.Uuid
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  alarmCodeEnc    Bytes?
  padlockCodeEnc  Bytes?
  alarmCode       String?
  padlockCode     String?
  entryStepsMd    String?
  lockboxId       String?
  hazards         String?
  updatedAt       DateTime @updatedAt
  updatedBy       String?  @db.Uuid
}

model PatrolSchedule {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId            String          @db.Uuid
  site              Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  kind              ScheduleKind    @default(PATROL)
  dayOfWeek         DayOfWeek
  frequency         PatrolFrequency @default(WEEKLY)
  assignedOfficerId String?         @db.Uuid
  assignedOfficer   User?           @relation(fields: [assignedOfficerId], references: [id])
  active            Boolean         @default(true)
  startsOn          DateTime?
  endsOn            DateTime?

  visits            PatrolVisit[]

  @@index([siteId])
  @@index([assignedOfficerId])
  @@index([kind])
}

model PatrolVisit {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId             String          @db.Uuid
  site               Site            @relation(fields: [siteId], references: [id])
  patrolScheduleId   String?         @db.Uuid
  patrolSchedule     PatrolSchedule? @relation(fields: [patrolScheduleId], references: [id])
  officerId          String?         @db.Uuid
  officer            User?           @relation(fields: [officerId], references: [id])
  scheduledAt        DateTime
  arrivedAt          DateTime?
  departedAt         DateTime?
  status             VisitStatus     @default(PENDING)
  gpsLat             Float?
  gpsLng             Float?
  photoUrls          String[]        @default([])
  notes              String?
  createdAt          DateTime        @default(now())

  job                Job?
  formSubmissions    FormSubmission[]

  @@index([siteId, scheduledAt])
  @@index([officerId, scheduledAt])
  @@index([status])
}

model LockUnlockSchedule {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId            String      @db.Uuid
  site              Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  unlockTime        String?
  lockdownTime      String?
  days              DayOfWeek[] @default([])
  assignedOfficerId String?     @db.Uuid
  assignedOfficer   User?       @relation(fields: [assignedOfficerId], references: [id])
  active            Boolean     @default(true)

  @@index([siteId])
  @@index([assignedOfficerId])
}

model AlarmEvent {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId          String         @db.Uuid
  site            Site           @relation(fields: [siteId], references: [id])
  source          AlarmSource
  receivedAt      DateTime       @default(now())
  rawSubject      String?
  rawBody         String?
  zone            String?
  priority        AlarmPriority  @default(MEDIUM)
  assignedToId    String?        @db.Uuid
  assignedTo      User?          @relation("AlarmAssignedTo", fields: [assignedToId], references: [id])
  outcome         AlarmOutcome?
  closedAt        DateTime?
  notes           String?
  createdAt       DateTime       @default(now())

  job             Job?

  @@index([siteId, receivedAt])
  @@index([assignedToId])
  @@index([priority])
}

model OnboardingPipeline {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId            String           @db.Uuid
  site              Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  program           CustomerProgram
  stage             OnboardingStage  @default(PROPOSED)
  targetGoLiveDate  DateTime?
  cancelReason      String?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  jobs              Job[]

  @@index([siteId])
  @@index([stage])
}

model ActivityLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @db.Uuid
  user        User?    @relation(fields: [userId], references: [id])
  entity      String
  entityId    String
  action      String
  diff        Json?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}

model Partner {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String          @unique
  role        PartnerRole
  preferred   PartnerChannel  @default(EMAIL)
  emailIntake String?
  notes       String?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  contacts        PartnerContact[]
  jobs            Job[]
  sites           Site[]          @relation("PartnerSites")
  formTemplates   FormTemplate[]

  @@index([role])
  @@index([active])
}

model PartnerContact {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partnerId   String   @db.Uuid
  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  role        String?
  notes       String?

  @@index([partnerId])
}

model Job {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type                  JobType
  source                JobSource
  status                JobStatus     @default(OPEN)
  priority              AlarmPriority @default(MEDIUM)

  siteId                String?       @db.Uuid
  site                  Site?         @relation(fields: [siteId], references: [id])

  customerId            String?       @db.Uuid
  customer              Customer?     @relation(fields: [customerId], references: [id])

  partnerId             String?       @db.Uuid
  partner               Partner?      @relation(fields: [partnerId], references: [id])

  onboardingPipelineId  String?       @db.Uuid
  onboardingPipeline    OnboardingPipeline? @relation(fields: [onboardingPipelineId], references: [id], onDelete: SetNull)

  responderType         ResponderType?
  assignedToUserId      String?       @db.Uuid
  assignedTo            User?         @relation("JobResponderUser", fields: [assignedToUserId], references: [id])
  externalResponder     String?

  alarmEventId          String?       @unique @db.Uuid
  alarmEvent            AlarmEvent?   @relation(fields: [alarmEventId], references: [id])
  patrolVisitId         String?       @unique @db.Uuid
  patrolVisit           PatrolVisit?  @relation(fields: [patrolVisitId], references: [id])

  scheduledFor          DateTime?
  startedAt             DateTime?
  completedAt           DateTime?

  reportedViaPartnerApp Boolean       @default(false)
  partnerReportRef      String?

  billedAmount          Decimal?      @db.Decimal(10, 2)
  paidAmount            Decimal?      @db.Decimal(10, 2)
  payRateUnit           String?

  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  formSubmissions       FormSubmission[]

  @@index([siteId, status])
  @@index([assignedToUserId, status])
  @@index([customerId])
  @@index([partnerId])
  @@index([onboardingPipelineId])
  @@index([scheduledFor])
  @@index([status])
}

model FormSubmission {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form                SubmissionForm
  formTemplateId      String?         @db.Uuid
  formTemplate        FormTemplate?   @relation(fields: [formTemplateId], references: [id], onDelete: SetNull)
  siteId              String?         @db.Uuid
  site                Site?           @relation(fields: [siteId], references: [id])
  jobId               String?         @db.Uuid
  job                 Job?            @relation(fields: [jobId], references: [id])
  patrolVisitId       String?         @db.Uuid
  patrolVisit         PatrolVisit?    @relation(fields: [patrolVisitId], references: [id], onDelete: SetNull)

  submittedByUserId   String?         @db.Uuid
  submittedBy         User?           @relation("SubmittedByUser", fields: [submittedByUserId], references: [id])
  officerNameRaw      String
  arrivedAt           DateTime?
  departedAt          DateTime?

  payload             Json            @default("{}")

  submittedAt         DateTime        @default(now())

  review              ReportReview?

  @@index([siteId, submittedAt])
  @@index([jobId])
  @@index([submittedByUserId])
  @@index([form])
  @@index([formTemplateId])
  @@index([patrolVisitId])
}

model FormTemplate {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  jobType      SubmissionForm?
  scope        TemplateScope
  customerId   String?        @db.Uuid
  customer     Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  partnerId    String?        @db.Uuid
  partner      Partner?       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  siteId       String?        @db.Uuid
  site         Site?          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  fields       Json           @default("[]")
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  createdById  String?        @db.Uuid
  createdBy    User?          @relation("FormTemplateAuthor", fields: [createdById], references: [id])

  submissions  FormSubmission[]

  @@index([scope, jobType, active])
  @@index([customerId])
  @@index([partnerId])
  @@index([siteId])
}

model ReportReview {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId    String         @unique @db.Uuid
  submission      FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  status          ReviewStatus   @default(PENDING)
  reviewerId      String?        @db.Uuid
  reviewer        User?          @relation("ReportReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  edits           Json?
  reviewerNotes   String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  clientReports   ClientReport[]

  @@index([status, createdAt])
}

model ClientReport {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId        String         @db.Uuid
  review          ReportReview   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  channel         ReportChannel  @default(EMAIL)
  toAddress       String
  subject         String?
  pdfUrl          String?
  status          ReportStatus   @default(PENDING)
  sentAt          DateTime?
  failureReason   String?

  createdAt       DateTime       @default(now())

  @@index([reviewId])
  @@index([status])
}
